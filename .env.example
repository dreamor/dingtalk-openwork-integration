# 钉钉 + OpenCode 集成系统配置

# ============== 钉钉配置 ==============
# 钉钉应用 Key (ClientID)
DINGTALK_APP_KEY=your_dingtalk_app_key

# 钉钉应用 Secret (ClientSecret)
DINGTALK_APP_SECRET=your_dingtalk_app_secret

# 机器人访问令牌 (Access Token)
DINGTALK_ACCESS_TOKEN=your_access_token

# 机器人加密密钥 (AES Key，需要 43 位 Base64 编码)
DINGTALK_AES_KEY=your_aes_key_here

# 签名密钥 (Signing Secret)
DINGTALK_SIGNING_SECRET=your_signing_secret_here

# ============== Gateway 配置 ==============
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
# API 访问令牌（可选，用于保护敏感接口）
GATEWAY_API_TOKEN=your_api_token_here

# ============== OpenCode CLI 配置 ==============
# 是否启用 OpenCode
OPENCODE_ENABLED=true

# OpenCode 命令路径（默认 opencode，如不在 PATH 中请指定完整路径）
OPENCODE_COMMAND=opencode

# OpenCode 执行超时时间 (毫秒，默认 2 分钟)
OPENCODE_TIMEOUT=120000

# 最大重试次数
OPENCODE_MAX_RETRIES=1

# ============== 会话管理配置 ==============
# 会话生存时间 (毫秒，默认 30 分钟)
SESSION_TTL=1800000

# 最大历史消息数
SESSION_MAX_HISTORY=50

# ============== 消息队列配置 ==============
# 每个用户最大并发数
MQ_MAX_CONCURRENT_PER_USER=3

# 全局最大并发数
MQ_MAX_CONCURRENT_GLOBAL=10

# 令牌桶最大令牌数（流量控制）
MQ_RATE_LIMIT_TOKENS=10

# ============== Stream 模式配置（推荐） ==============
# 是否启用 Stream 模式（无需内网穿透）
STREAM_ENABLED=true

# 最大重连次数
STREAM_MAX_RECONNECT=5

# ============== 轮询模式配置（备用） ==============
# 是否启用轮询模式
POLLING_ENABLED=true

# 轮询间隔 (毫秒)
POLLING_INTERVAL=3000